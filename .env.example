TELEGRAM_BOT_TOKEN=123456789:replace_with_token_from_botfather

# Через запятую: ID чатов, где бот имеет право работать.
# Пример для группы: ALLOWED_CHAT_IDS=-1001234567890
ALLOWED_CHAT_IDS=

# Через запятую: ID владельцев. Используется для /chatid, /resetstats и выбора подарков owner при 777.
OWNER_USER_IDS=

DATABASE_PATH=bot_stats.sqlite3

# Рандомный приз для трех одинаковых символов: BAR/BAR/BAR, виноград/виноград/виноград, лимон/лимон/лимон.
SMALL_GIFTS=роза,мишка,сердце,подарок
